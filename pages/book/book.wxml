<view class="page" style="padding: 24rpx;">
  <block wx:if="{{story}}">
    <view style="font-size: 40rpx; font-weight: 700;">
      {{story.title}}
    </view>

    <view style="margin-top: 12rpx; color: #666; font-size: 24rpx;">
      年龄：{{story.age}}
    </view>

    <view style="margin-top:20rpx;">
      <button bindtap="goBookChat">
        继续聊这本书
      </button>
    </view>

    <view style="margin-top: 24rpx; background:#fff; border-radius:20rpx; padding:24rpx; line-height:1.9; white-space:pre-wrap;">
      {{story.content}}
    </view>
  </block>
</view>