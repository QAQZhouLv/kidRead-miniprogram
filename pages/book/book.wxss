.page {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.reader-day {
  color: #403a31;
}

.reader-night {
  color: #f2f2f2;
}

.brightness-mask {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 110;
}

/* 顶部导航 */
.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 20rpx;
  padding-right: 20rpx;
  box-sizing: content-box;
}

.nav-left {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.nav-right {
  width: 88rpx;
}

.nav-back {
  width: 40rpx;
  margin-right: 8rpx;
  font-size: 62rpx;
  color: #2f2b25;
  line-height: 1;
}

.nav-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #4a4438;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reader-night .nav-back,
.reader-night .nav-title {
  color: #f3f3f3;
}

/* 页面主体，专门避让顶部导航 */
.page-body {
  height: 100vh;
  box-sizing: border-box;
}

.reader-scroll {
  height: 100%;
  box-sizing: border-box;
}

/* 正文 */
.reader-article {
  padding: 20rpx 34rpx 0;
  box-sizing: border-box;
}

.content-paragraph {
  line-height: 2.05;
  text-indent: 2em;
  margin-bottom: 28rpx;
  text-align: justify;
  word-break: break-word;
  letter-spacing: 0;
}

.content-paragraph:last-child {
  margin-bottom: 0;
}

.content-paragraph-text {
  display: inline;
  line-height: inherit;
  color: inherit;
  font-size: inherit;
}

.sentence-text {
  display: inline;
  line-height: inherit;
  color: inherit;
  font-size: inherit;
}

.sentence-text-reading {
  text-decoration: underline;
  text-decoration-thickness: 3rpx;
  text-underline-offset: 10rpx;
}

.reader-day .sentence-text-reading {
  text-decoration-color: #6b7a45;
}

.reader-night .sentence-text-reading {
  text-decoration-color: #f5f5f5;
}

.reader-bottom-safe {
  height: 320rpx;
}

/* 右侧悬浮按钮 */
.floating-actions {
  position: fixed;
  right: 22rpx;
  bottom: 190rpx;
  z-index: 150;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.floating-btn {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: #6b6556;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}

.reader-night .floating-btn {
  background: #444;
  color: #fff;
}

/* 底部工具栏 */
.bottom-tools {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 145;

  display: flex;
  justify-content: center;
  gap: 40rpx;

  padding: 16rpx 0 calc(env(safe-area-inset-bottom) + 12rpx);
}

.bottom-tools-day {
  background: #ece6c9;
  border-top: 1rpx solid #e0dac0;
}

.bottom-tools-night {
  background: #1f1f1f;
  border-top: 1rpx solid #333;
}

.bottom-tool {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.bottom-tool-text {
  font-size: 24rpx;
  color: #2f2b25;
}

.reader-night .bottom-tool-text {
  color: #f5f5f5;
}

.bottom-tool-active .bottom-tool-text {
  font-weight: 600;
}

/* 设置面板 */
.settings-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 80rpx);
  z-index: 160;

  padding: 24rpx 28rpx 28rpx;
}

.settings-panel-day {
  background: #ece6c9;
  border-top: 1rpx solid #e0dac0;
}

.settings-panel-night {
  background: #1f1f1f;
  border-top: 1rpx solid #333;
}

.settings-row {
  margin-bottom: 24rpx;
}

.settings-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  color: #2f2b25;
}

.settings-panel-night .settings-label {
  color: #f3f3f3;
}

.font-size-actions,
.bg-options,
.page-effect-options {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.size-btn,
.effect-btn {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #e2dcc5;
  color: #2f2b25;
}

.settings-panel-night .size-btn,
.settings-panel-night .effect-btn {
  background: #2c2c2c;
  color: #f4f4f4;
}

.effect-btn.active {
  outline: 2rpx solid #859767;
}

.size-value {
  font-size: 30rpx;
  color: #2f2b25;
}

.settings-panel-night .size-value {
  color: #f3f3f3;
}

/* 背景色按钮 */
.bg-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 1rpx solid #ccc;
  box-sizing: border-box;
}

.bg-dot-active {
  border: 3rpx solid #859767;
}

.bg-white { background: #F8F7F2; }
.bg-pink { background: #F6ECEC; }
.bg-green { background: #E8F1E4; }
.bg-theme { background: #ECE6C9; }
.bg-black { background: #111111; }
.bg-gray { background: #3E3E42; }
.bg-brown { background: #2B1D16; }