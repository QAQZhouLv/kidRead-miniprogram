
.page {
  min-height: 100vh;
  position: relative;
}

.custom-nav {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  top: 10rpx;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 18rpx;
  padding-right: 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 248, 236, 0.92);
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
  box-shadow: 0 14rpx 34rpx rgba(81, 67, 44, 0.08);
}

.nav-left,
.nav-right {
  width: 96rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  line-height: 1;
  color: #544d40;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #4f473a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reader {
  margin: 0 24rpx 30rpx;
  padding: 26rpx 28rpx 90rpx;
  border-radius: 40rpx;
  background: rgba(255, 248, 236, 0.9);
  box-shadow: 0 16rpx 40rpx rgba(81, 67, 44, 0.08);
  box-sizing: border-box;
}

.chapter-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #4a4438;
  line-height: 1.4;
  margin-bottom: 26rpx;
}

.content-paragraph {
  font-size: 34rpx;
  line-height: 2.02;
  color: #403a31;
  text-indent: 2em;
  margin-bottom: 24rpx;
}

.reader-actions {
  position: fixed;
  right: 24rpx;
  bottom: 74rpx;
  z-index: 130;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.reader-action {
  width: 116rpx;
  height: 116rpx;
  border-radius: 58rpx;
  color: #3f382f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: 2rpx solid rgba(255, 248, 236, 0.72);
  text-shadow: none;
  box-shadow: 0 14rpx 28rpx rgba(0, 0, 0, 0.12);
}

.theme-meadow .reader-action,
.theme-meadow .chapter-title { background: transparent; color: #35553A; }
.theme-meadow .reader-action { background: rgba(96, 171, 112, 0.96); }

.theme-ocean .reader-action,
.theme-ocean .chapter-title { background: transparent; color: #2C5070; }
.theme-ocean .reader-action { background: rgba(69, 131, 189, 0.96); }

.theme-berry .reader-action,
.theme-berry .chapter-title { background: transparent; color: #70414A; }
.theme-berry .reader-action { background: rgba(220, 104, 114, 0.96); }

.theme-sunny .reader-action,
.theme-sunny .chapter-title { background: transparent; color: #755331; }
.theme-sunny .reader-action { background: rgba(233, 107, 77, 0.96); }

.theme-citrus .reader-action,
.theme-citrus .chapter-title { background: transparent; color: #6D4728; }
.theme-citrus .reader-action { background: rgba(242, 131, 62, 0.97); }

.theme-lagoon .reader-action,
.theme-lagoon .chapter-title { background: transparent; color: #2F5E58; }
.theme-lagoon .reader-action { background: rgba(98, 180, 165, 0.96); }