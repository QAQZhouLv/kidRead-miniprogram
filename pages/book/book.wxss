.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #ece6c9;
}

/* 背景层 */
.page-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  background:
    linear-gradient(to bottom, rgba(221, 186, 120, 0.72) 0%, rgba(236, 230, 201, 0.92) 16%, #ece6c9 34%, #ece6c9 100%);
  pointer-events: none;
}

.top-glow {
  position: fixed;
  left: -80rpx;
  right: -80rpx;
  top: -120rpx;
  height: 280rpx;
  z-index: 0;
  background: radial-gradient(circle at center, rgba(255, 248, 224, 0.5) 0%, rgba(255, 248, 224, 0.18) 42%, rgba(255, 248, 224, 0) 72%);
  pointer-events: none;
}

/* 顶部导航 */
.custom-nav {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  top: 10rpx;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 18rpx;
  padding-right: 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 248, 236, 0.72);
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
  box-shadow: 0 10rpx 26rpx rgba(81, 67, 44, 0.06);
}

.nav-left,
.nav-right {
  width: 96rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  line-height: 1;
  color: #544d40;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.04);

  transform: translateY(-4rpx);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #4f473a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 12rpx;
}

/* 滚动阅读区域 */
.reader-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
  box-sizing: border-box;
}

.reader-shell {
  margin: 0 20rpx;
  padding: 0;
}


.reader-body {
  background: rgba(255, 248, 236, 0.72);
  border-radius: 34rpx;
  padding: 24rpx 30rpx 42rpx;
  box-shadow: 0 14rpx 34rpx rgba(81, 67, 44, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
}

.content-paragraph {
  font-size: 34rpx;
  line-height: 2;
  color: #403a31;
  text-indent: 2em;
  margin-bottom: 28rpx;
  letter-spacing: 0;
  word-break: break-word;
  text-align: justify;
}

.content-paragraph:last-child {
  margin-bottom: 0;
}

.bottom-safe {
  height: 180rpx;
}

/* 听 / 聊 */
.reader-actions {
  position: fixed;
  right: 24rpx;
  bottom: 74rpx;
  z-index: 130;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.reader-action {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  color: #fffdf8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.44);
}

/* 不同主题下按钮颜色 */
.theme-meadow .reader-action {
  background: rgba(96, 171, 112, 0.96);
}
.theme-ocean .reader-action {
  background: rgba(69, 131, 189, 0.96);
}
.theme-berry .reader-action {
  background: rgba(220, 104, 114, 0.96);
}
.theme-sunny .reader-action {
  background: rgba(233, 107, 77, 0.96);
}
.theme-citrus .reader-action {
  background: rgba(242, 131, 62, 0.97);
}
.theme-lagoon .reader-action {
  background: rgba(98, 180, 165, 0.96);
}

/* 标题颜色跟着主题轻微变化 */
.theme-meadow .book-title,
.theme-meadow .nav-title {
  color: #35553A;
}

.theme-ocean .book-title,
.theme-ocean .nav-title {
  color: #2C5070;
}

.theme-berry .book-title,
.theme-berry .nav-title {
  color: #70414A;
}

.theme-sunny .book-title,
.theme-sunny .nav-title {
  color: #755331;
}

.theme-citrus .book-title,
.theme-citrus .nav-title {
  color: #6D4728;
}

.theme-lagoon .book-title,
.theme-lagoon .nav-title {
  color: #2F5E58;
}