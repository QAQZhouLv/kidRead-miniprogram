.page {
  box-sizing: border-box;
  min-height: 100vh;
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 24rpx;
  padding-right: 24rpx;
  border-radius: 0 0 32rpx 32rpx;
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
  box-shadow: 0 14rpx 34rpx rgba(81, 67, 44, 0.08);
}

.nav-side {
  width: 96rpx;
  flex-shrink: 0;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 700;
}

.nav-bell {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.nav-bell-static {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  opacity: 1;
}

.page-content {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.chat-list {
  border-radius: 0;
  box-shadow: none;
  padding: 0;
  background: transparent;
}


.chat-list-top {
  margin-top: 0;
}

.draft-bubble-wrap {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 178rpx;
  z-index: 80;
}

.draft-bubble {
  border: 3rpx dashed rgba(130, 118, 98, 0.22);
  border-radius: 28rpx;
  padding: 18rpx 22rpx;
  line-height: 1.7;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.04);
}

.archive-wrap {
  position: fixed;
  right: 24rpx;
  bottom: 144rpx;
  z-index: 90;
}

.archive-btn {
  width: 136rpx;
  min-width: 136rpx;
  height: 72rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  color: #fff !important;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.1);
}

.archive-btn::after {
  border: none;
}

.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(52, 40, 27, 0.22);
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-panel {
  width: 84%;
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 700;
}

.edit-close,
.edit-confirm {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
}

.edit-body {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
}

.edit-input {
  flex: 1;
  min-height: 76rpx;
  border-bottom: 3rpx solid rgba(111, 101, 86, 0.18);
  font-size: 30rpx;
}

.edit-confirm {
  margin-left: 18rpx;
}