.page {
  box-sizing: border-box;
  background: #f7f8fa;
  min-height: 100vh;
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 24rpx;
  padding-right: 24rpx;
  background: rgba(247, 248, 250, 0.96);
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
}

.nav-side {
  width: 96rpx;
  flex-shrink: 0;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  line-height: 1;
}

.nav-bell {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.nav-bell-on {
  background: #eff5ff;
  border: 2rpx solid #d5e6ff;
}

.nav-bell-off {
  background: #ffffff;
  border: 2rpx solid #e6e6e6;
}

.nav-bell-image {
  width: 38rpx;
  height: 38rpx;
}

.page-content {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8a8a8a;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.age-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.age-input {
  width: 120rpx;
  height: 64rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.chat-list {
  margin-bottom: 24rpx;
}

.draft-bubble-wrap {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 170rpx;
  z-index: 80;
}

.draft-bubble {
  background: #ffffff;
  border: 2rpx dashed #d5d5d5;
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  color: #555;
  line-height: 1.7;
}

.archive-wrap {
  position: fixed;
  right: 24rpx;
  bottom: 140rpx;
  z-index: 90;
}

.archive-btn {
  min-width: 140rpx;
  background: #fff7e8;
  color: #a86500;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.25);
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-panel {
  width: 80%;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 600;
}

.edit-close {
  font-size: 36rpx;
  color: #999;
}

.edit-body {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.edit-input {
  flex: 1;
  border-bottom: 2rpx solid #ddd;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.edit-confirm {
  margin-left: 20rpx;
  font-size: 34rpx;
  color: #1677ff;
}
