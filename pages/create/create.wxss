
.page {
  box-sizing: border-box;
  min-height: 100vh;
}

.custom-nav {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  top: 10rpx;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 18rpx;
  padding-right: 18rpx;
  border-radius: 32rpx;
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
  box-shadow: 0 14rpx 34rpx rgba(81, 67, 44, 0.08);
}

.nav-side { width: 96rpx; flex-shrink: 0; }

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 700;
}

.nav-bell {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 3rpx solid transparent;
  overflow: hidden;
}

.nav-bell-off { opacity: 0.82; }

.page-content {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.page-header,
.top-bar,
.chat-list {
  border-radius: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(81, 67, 44, 0.05);
}

.page-header {
  padding: 30rpx 28rpx;
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 20rpx 26rpx;
}

.age-box {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
}

.age-input {
  width: 110rpx;
  height: 54rpx;
  text-align: center;
  background: transparent;
  font-weight: 700;
}

.chat-list {
  padding: 18rpx;
}

.draft-bubble-wrap {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 178rpx;
  z-index: 80;
}

.draft-bubble {
  border: 3rpx dashed rgba(130, 118, 98, 0.22);
  border-radius: 28rpx;
  padding: 18rpx 22rpx;
  line-height: 1.7;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.04);
}

.archive-wrap {
  position: fixed;
  right: 24rpx;
  bottom: 144rpx;
  z-index: 90;
}

.archive-btn {
  min-width: 164rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  border: none;
  color: #fff !important;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.1);
}

.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(52, 40, 27, 0.22);
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-panel {
  width: 84%;
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 700;
}

.edit-close,
.edit-confirm {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
}

.edit-body {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
}

.edit-input {
  flex: 1;
  min-height: 76rpx;
  border-bottom: 3rpx solid rgba(111, 101, 86, 0.18);
  font-size: 30rpx;
}

.edit-confirm {
  margin-left: 18rpx;
}
