.page {
  min-height: 100vh;
  background: #fff8ec;
}

.theme-meadow.page,
.theme-sunny.page,
.theme-citrus.page,
.theme-dream.page,
.theme-ocean.page,
.theme-berry.page {
  background: transparent;
}

.shelf-page {
  padding: 24rpx 24rpx 36rpx;
  box-sizing: border-box;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-box {
  flex: 1;
  height: 78rpx;
  padding: 0 16rpx 0 24rpx;
  border-radius: 22rpx;
  border: 2rpx solid #dbe4f2;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  font-size: 28rpx;
}

.search-placeholder {
  color: #b1b8c6;
}

.search-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-cancel {
  flex-shrink: 0;
  font-size: 26rpx;
}

.search-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(31, 56, 88, 0.05);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
}

.panel-action,
.panel-desc {
  font-size: 24rpx;
}

.panel-empty {
  padding: 36rpx 0 20rpx;
  text-align: center;
  font-size: 26rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-item {
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff8ec;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-keyword {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-delete {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shelf-main {
  margin-top: 20rpx;
}

.loading-text {
  padding: 80rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.empty-wrap {
  margin-top: 40rpx;
  padding: 64rpx 36rpx;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 56, 88, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-emoji {
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.empty-btn {
  margin-top: 28rpx;
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.tab-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tab-row-alone {
  margin-bottom: 18rpx;
  justify-content: space-between;
}

.tab-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tab-count {
  font-size: 24rpx;
}

.tab-item {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  border: 2rpx solid #e4e9f2;
}

.section {
  margin-top: 22rpx;
}

.section:first-child {
  margin-top: 0;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.grid-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  column-gap: 18rpx;
  row-gap: 26rpx;
}

.book-item {
  min-width: 0;
}

.book-cover-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(45, 69, 102, 0.08);
  background: #eef2f7;
}

.recent-cover {
  aspect-ratio: 3 / 4;
}

.favorite-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  z-index: 3;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.08);
}

.book-title {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
}
