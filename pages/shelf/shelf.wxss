.page {
  min-height: 100vh;
  background: #f7f8fc;
}

.shelf-body {
  padding: 24rpx;
  box-sizing: border-box;
}

.shelf-tip {
  padding: 80rpx 0;
  text-align: center;
  color: #7f8796;
  font-size: 28rpx;
}

.empty-wrap {
  margin-top: 80rpx;
  padding: 64rpx 36rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 56, 88, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-emoji {
  font-size: 72rpx;
  line-height: 1;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2d3440;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8a92a3;
}

.empty-btn {
  margin-top: 28rpx;
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #6fa8ff 0%, #8ec5ff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.story-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.story-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 20rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(31, 56, 88, 0.06);
}

.cover-box {
  width: 180rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.story-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.story-title {
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #243041;

  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.story-meta-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6f7785;
}

.meta-label {
  color: #98a0af;
}

.meta-value {
  color: #5b6270;
}

.story-time {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #a0a7b4;
}