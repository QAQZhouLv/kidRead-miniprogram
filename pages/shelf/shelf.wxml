<view class="page {{themeClass}}">
  <view class="shelf-page">
    <view class="search-row">
      <view class="search-box">
        <input
          class="search-input"
          placeholder="搜索书名"
          placeholder-class="search-placeholder"
          value="{{keyword}}"
          confirm-type="search"
          bindinput="onSearchInput"
          bindfocus="onSearchFocus"
          bindconfirm="onSearchConfirm"
        />
        <view class="search-icon" bindtap="onTapSearchIcon">🔍</view>
      </view>

      <view
        wx:if="{{showSearchPanel || keyword}}"
        class="search-cancel"
        bindtap="onCancelSearch"
      >
        取消
      </view>
    </view>

    <view wx:if="{{showSearchPanel}}" class="search-panel">
      <block wx:if="{{!keyword}}">
        <view class="panel-header">
          <view class="panel-title">搜索历史</view>
          <view wx:if="{{searchHistory.length}}" class="panel-action" bindtap="onClearHistory">
            清空
          </view>
        </view>

        <block wx:if="{{searchHistory.length}}">
          <view class="history-list">
            <block wx:for="{{searchHistory}}" wx:key="*this">
              <view class="history-item">
                <view
                  class="history-keyword"
                  data-keyword="{{item}}"
                  bindtap="onUseHistoryKeyword"
                >
                  {{item}}
                </view>
                <view
                  class="history-delete"
                  data-keyword="{{item}}"
                  bindtap="onDeleteHistoryItem"
                >
                  ×
                </view>
              </view>
            </block>
          </view>
        </block>

        <view wx:else class="panel-empty">还没有搜索历史</view>
      </block>

      <block wx:else>
        <view class="panel-header">
          <view class="panel-title">搜索结果</view>
          <view class="panel-desc">共 {{filteredStories.length}} 本</view>
        </view>

        <block wx:if="{{filteredStories.length}}">
          <view class="grid-list">
            <block wx:for="{{filteredStories}}" wx:key="id">
              <view
                class="book-item"
                data-id="{{item.id}}"
                data-story="{{item}}"
                data-source="search"
                bindtap="openBook"
                bindlongpress="onBookLongPress"
              >
                <view class="book-cover-wrap">
                  <book-cover
                    title="{{item.displayTitle}}"
                    imageUrl="{{item.ai_cover_url}}"
                    coverStatus="{{item.cover_status}}"
                    themeIndex="{{item.themeIndex}}"
                    size="medium"
                  />
                  <view wx:if="{{item.is_favorite}}" class="favorite-badge">❤</view>
                </view>

                <view class="book-title">{{item.displayTitle}}</view>
                <view class="book-sub">{{item.displayDate}}</view>
              </view>
            </block>
          </view>
        </block>

        <view wx:else class="panel-empty">没有找到相关书籍</view>
      </block>
    </view>

    <view wx:else class="shelf-main">
      <block wx:if="{{loading}}">
        <view class="loading-text">书架加载中...</view>
      </block>

      <block wx:elif="{{stories.length === 0}}">
        <view class="empty-wrap">
          <view class="empty-emoji">📚</view>
          <view class="empty-title">书架里还没有故事</view>
          <view class="empty-desc">先去创作一个属于你的故事吧</view>
          <view class="empty-btn" bindtap="goCreate">去创作</view>
        </view>
      </block>

      <block wx:else>
        <view wx:if="{{recentStories.length}}" class="section">
          <view class="section-title">最近阅读</view>
          <view class="grid-list recent-grid">
            <block wx:for="{{recentStories}}" wx:key="id">
              <view
                class="book-item"
                data-id="{{item.id}}"
                data-story="{{item}}"
                data-source="recent"
                bindtap="openBook"
                bindlongpress="onBookLongPress"
              >
                <view class="book-cover-wrap recent-cover">
                  <book-cover
                    title="{{item.displayTitle}}"
                    imageUrl="{{item.ai_cover_url}}"
                    coverStatus="{{item.cover_status}}"
                    themeIndex="{{item.themeIndex}}"
                    size="medium"
                  />
                  <view wx:if="{{item.is_favorite}}" class="favorite-badge">❤</view>
                </view>

                <view class="book-title">{{item.displayTitle}}</view>
                <!-- <view class="book-sub">年龄 {{item.displayAge}}</view> -->
              </view>
            </block>
          </view>
        </view>

        <view class="section">
          <view class="tab-row tab-row-alone">
            <view class="tab-left">
              <view
                class="tab-item {{activeTab === 'all' ? 'tab-item-active' : ''}}"
                data-tab="all"
                bindtap="onSwitchTab"
              >
                全部书架
              </view>
              <view
                class="tab-item {{activeTab === 'favorite' ? 'tab-item-active' : ''}}"
                data-tab="favorite"
                bindtap="onSwitchTab"
              >
                喜欢
              </view>
            </view>

            <view class="tab-count">
              {{activeTab === 'all' ? ('共 ' + stories.length + ' 本') : ('共 ' + favoriteStories.length + ' 本')}}
            </view>
          </view>

          <block wx:if="{{activeTab === 'all'}}">
            <view class="grid-list">
              <block wx:for="{{stories}}" wx:key="id">
                <view
                  class="book-item"
                  data-id="{{item.id}}"
                  data-story="{{item}}"
                  data-source="all"
                  bindtap="openBook"
                  bindlongpress="onBookLongPress"
                >
                  <view class="book-cover-wrap">
                    <book-cover
                      title="{{item.displayTitle}}"
                      imageUrl="{{item.ai_cover_url}}"
                      coverStatus="{{item.cover_status}}"
                      themeIndex="{{item.themeIndex}}"
                      size="medium"
                    />
                    <view wx:if="{{item.is_favorite}}" class="favorite-badge">❤</view>
                  </view>

                  <view class="book-title">{{item.displayTitle}}</view>
                  <!-- <view class="book-sub">年龄 {{item.displayAge}}</view> -->
                </view>
              </block>
            </view>
          </block>

          <block wx:else>
            <block wx:if="{{favoriteStories.length}}">
              <view class="grid-list">
                <block wx:for="{{favoriteStories}}" wx:key="id">
                  <view
                    class="book-item"
                    data-id="{{item.id}}"
                    data-story="{{item}}"
                    data-source="favorite"
                    bindtap="openBook"
                    bindlongpress="onBookLongPress"
                  >
                    <view class="book-cover-wrap">
                      <book-cover
                        title="{{item.displayTitle}}"
                        imageUrl="{{item.ai_cover_url}}"
                        coverStatus="{{item.cover_status}}"
                        themeIndex="{{item.themeIndex}}"
                        size="medium"
                      />
                      <view wx:if="{{item.is_favorite}}" class="favorite-badge">❤</view>
                    </view>

                    <view class="book-title">{{item.displayTitle}}</view>
                    <!-- <view class="book-sub">年龄 {{item.displayAge}}</view> -->
                  </view>
                </block>
              </view>
            </block>

            <view wx:else class="panel-empty">你还没有标记喜欢的书</view>
          </block>
        </view>
      </block>
    </view>
  </view>

  <!-- 自定义重命名弹窗 -->
  <view wx:if="{{renameDialogVisible}}" class="rename-mask" catchtouchmove="true">
    <view class="rename-dialog">
      <view class="rename-title">给书换个名字</view>
      <view class="rename-subtitle">换一个更贴合故事内容的书名吧</view>

      <view class="rename-input-wrap">
        <input
          class="rename-input"
          value="{{renameValue}}"
          maxlength="30"
          placeholder="请输入新的书名"
          placeholder-class="rename-input-placeholder"
          focus="{{renameDialogVisible}}"
          bindinput="onRenameInput"
        />
      </view>

      <view class="rename-tip">
        原书名：{{renameOriginalTitle}}
      </view>

      <view class="rename-actions">
        <view class="rename-btn rename-btn-cancel" bindtap="closeRenameDialog">
          取消
        </view>
        <view class="rename-btn rename-btn-confirm" bindtap="submitRename">
          {{submittingRename ? '保存中...' : '保存'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义操作菜单 -->
  <view wx:if="{{actionSheetVisible}}" class="action-mask" catchtouchmove="true" bindtap="closeActionSheet">
    <view class="action-sheet" catchtap="noop">
      <view class="action-sheet-header">
        <view class="action-sheet-title">{{actionSheetTitle}}</view>
      </view>

      <view class="action-list">
        <view class="action-item" data-action="rename" bindtap="onActionTap">重命名</view>

        <block wx:if="{{actionSource === 'recent'}}">
          <view class="action-item" data-action="toggleFavorite" bindtap="onActionTap">
            {{actionStory.is_favorite ? '取消喜欢' : '设为喜欢'}}
          </view>
          <view class="action-item" data-action="removeRecent" bindtap="onActionTap">移出最近阅读</view>
          <view class="action-item action-item-danger" data-action="delete" bindtap="onActionTap">删除书籍</view>
        </block>

        <block wx:elif="{{actionSource === 'favorite'}}">
          <view class="action-item" data-action="removeFavorite" bindtap="onActionTap">移出喜欢</view>
          <view class="action-item action-item-danger" data-action="delete" bindtap="onActionTap">删除书籍</view>
        </block>

        <block wx:else>
          <view class="action-item" data-action="toggleFavorite" bindtap="onActionTap">
            {{actionStory.is_favorite ? '取消喜欢' : '设为喜欢'}}
          </view>
          <view class="action-item action-item-danger" data-action="delete" bindtap="onActionTap">删除书籍</view>
        </block>
      </view>

      <view class="action-cancel" bindtap="closeActionSheet">取消</view>
    </view>
  </view>
</view>