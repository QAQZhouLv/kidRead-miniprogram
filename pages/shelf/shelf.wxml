<view class="page">
  <view class="shelf-body">
    <block wx:if="{{loading}}">
      <view class="shelf-tip">书架加载中...</view>
    </block>

    <block wx:elif="{{stories.length === 0}}">
      <view class="empty-wrap">
        <view class="empty-emoji">📚</view>
        <view class="empty-title">书架里还没有故事</view>
        <view class="empty-desc">先去创作一个属于你的故事吧</view>
        <view class="empty-btn" bindtap="goCreate">去创作</view>
      </view>
    </block>

    <block wx:else>
      <view class="story-list">
        <block wx:for="{{stories}}" wx:key="id">
          <view class="story-card" data-id="{{item.id}}" bindtap="openBook">
            <view class="cover-box">
              <book-cover
                title="{{item.displayTitle}}"
                imageUrl="{{item.ai_cover_url}}"
                coverStatus="{{item.cover_status}}"
                themeIndex="{{item.themeIndex}}"
                size="medium"
              />
            </view>

            <view class="story-info">
              <view class="story-title">{{item.displayTitle}}</view>

              <view class="story-meta-row">
                <text class="meta-label">年龄：</text>
                <text class="meta-value">{{item.age || '未知'}}</text>
              </view>

              <view class="story-meta-row">
                <text class="meta-label">封面：</text>
                <text class="meta-value">
                  {{item.ai_cover_url ? (item.cover_status === 'ready' ? 'AI正式封面' : 'AI封面生成中') : '系统默认封面'}}
                </text>
              </view>

              <view class="story-time">{{item.displayDate}}</view>
            </view>
          </view>
        </block>
      </view>
    </block>
  </view>
</view>