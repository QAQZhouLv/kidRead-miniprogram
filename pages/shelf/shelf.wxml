<view class="page {{themeClass}}">
  <view class="shelf-page">
    <view class="search-row">
      <view class="search-box" style="background: {{theme.cardSurfaceStrong}}; border-color: {{theme.searchBorder}};">
        <input
          class="search-input"
          placeholder="搜索书名"
          placeholder-class="search-placeholder"
          value="{{keyword}}"
          confirm-type="search"
          bindinput="onSearchInput"
          bindfocus="onSearchFocus"
          bindconfirm="onSearchConfirm"
          style="color: {{theme.text}};"
        />
        <view class="search-icon" bindtap="onTapSearchIcon">
          <svg-icon name="search" color="{{theme.iconMuted}}" size="28rpx" />
        </view>
      </view>

      <view
        wx:if="{{showSearchPanel || keyword}}"
        class="search-cancel"
        bindtap="onCancelSearch"
        style="color: {{theme.mutedText}};"
      >
        取消
      </view>
    </view>

    <view wx:if="{{showSearchPanel}}" class="search-panel" style="background: {{theme.cardSurfaceStrong}};">
      <block wx:if="{{!keyword}}">
        <view class="panel-header">
          <view class="panel-title" style="color: {{theme.text}};">搜索历史</view>
          <view wx:if="{{searchHistory.length}}" class="panel-action" bindtap="onClearHistory" style="color: {{theme.mutedText}};">
            清空
          </view>
        </view>

        <block wx:if="{{searchHistory.length}}">
          <view class="history-list">
            <block wx:for="{{searchHistory}}" wx:key="*this">
              <view class="history-item">
                <view
                  class="history-keyword"
                  data-keyword="{{item}}"
                  bindtap="onUseHistoryKeyword"
                  style="color: {{theme.text}};"
                >
                  {{item}}
                </view>
                <view
                  class="history-delete"
                  data-keyword="{{item}}"
                  bindtap="onDeleteHistoryItem"
                >
                  <svg-icon name="close" color="{{theme.iconMuted}}" size="24rpx" />
                </view>
              </view>
            </block>
          </view>
        </block>

        <view wx:else class="panel-empty" style="color: {{theme.mutedText}};">还没有搜索历史</view>
      </block>

      <block wx:else>
        <view class="panel-header">
          <view class="panel-title" style="color: {{theme.text}};">搜索结果</view>
          <view class="panel-desc" style="color: {{theme.mutedText}};">共 {{filteredStories.length}} 本</view>
        </view>

        <block wx:if="{{filteredStories.length}}">
          <view class="grid-list">
            <block wx:for="{{filteredStories}}" wx:key="id">
              <view
                class="book-item"
                data-id="{{item.id}}"
                data-story="{{item}}"
                data-source="search"
                bindtap="openBook"
                bindlongpress="onBookLongPress"
              >
                <view class="book-cover-wrap">
                  <book-cover
                    title="{{item.displayTitle}}"
                    imageUrl="{{item.ai_cover_url}}"
                    coverStatus="{{item.cover_status}}"
                    themeIndex="{{item.themeIndex}}"
                    size="medium"
                  />
                  <view wx:if="{{item.is_favorite}}" class="favorite-badge">
                    <svg-icon name="heart" color="{{theme.accent}}" size="20rpx" />
                  </view>
                </view>

                <view class="book-title" style="color: {{theme.text}};">{{item.displayTitle}}</view>
                <view class="book-sub" style="color: {{theme.mutedText}};">{{item.displayDate}}</view>
              </view>
            </block>
          </view>
        </block>

        <view wx:else class="panel-empty" style="color: {{theme.mutedText}};">没有找到相关书籍</view>
      </block>
    </view>

    <view wx:else class="shelf-main">
      <block wx:if="{{loading}}">
        <view class="loading-text" style="color: {{theme.mutedText}};">书架加载中...</view>
      </block>

      <block wx:elif="{{stories.length === 0}}">
        <view class="empty-wrap" style="background: {{theme.cardSurfaceStrong}};">
          <view class="empty-emoji">
            <svg-icon name="book" color="{{theme.iconPrimary}}" size="72rpx" />
          </view>
          <view class="empty-title" style="color: {{theme.text}};">书架里还没有故事</view>
          <view class="empty-desc" style="color: {{theme.mutedText}};">先去创作一个属于你的故事吧</view>
          <view class="empty-btn" bindtap="goCreate" style="background: {{theme.emptyButtonGradient}}; color: {{theme.inverseText}};">去创作</view>
        </view>
      </block>

      <block wx:else>
        <view wx:if="{{recentStories.length}}" class="section">
          <view class="section-title" style="color: {{theme.text}};">最近阅读</view>
          <view class="grid-list recent-grid">
            <block wx:for="{{recentStories}}" wx:key="id">
              <view
                class="book-item"
                data-id="{{item.id}}"
                data-story="{{item}}"
                data-source="recent"
                bindtap="openBook"
                bindlongpress="onBookLongPress"
              >
                <view class="book-cover-wrap recent-cover">
                  <book-cover
                    title="{{item.displayTitle}}"
                    imageUrl="{{item.ai_cover_url}}"
                    coverStatus="{{item.cover_status}}"
                    themeIndex="{{item.themeIndex}}"
                    size="medium"
                  />
                  <view wx:if="{{item.is_favorite}}" class="favorite-badge">
                    <svg-icon name="heart" color="{{theme.accent}}" size="20rpx" />
                  </view>
                </view>

                <view class="book-title" style="color: {{theme.text}};">{{item.displayTitle}}</view>
              </view>
            </block>
          </view>
        </view>

        <view class="section">
          <view class="tab-row tab-row-alone">
            <view class="tab-left">
              <view
                class="tab-item {{activeTab === 'all' ? 'tab-item-active' : ''}}"
                data-tab="all"
                bindtap="onSwitchTab"
                style="{{activeTab === 'all' ? 'background:' + theme.emptyButtonGradient + '; color:' + theme.inverseText + '; border-color: transparent;' : 'background:' + theme.cardSurfaceStrong + '; color:' + theme.mutedText + '; border-color:' + theme.searchBorder + ';'}}"
              >
                全部书架
              </view>
              <view
                class="tab-item {{activeTab === 'favorite' ? 'tab-item-active' : ''}}"
                data-tab="favorite"
                bindtap="onSwitchTab"
                style="{{activeTab === 'favorite' ? 'background:' + theme.emptyButtonGradient + '; color:' + theme.inverseText + '; border-color: transparent;' : 'background:' + theme.cardSurfaceStrong + '; color:' + theme.mutedText + '; border-color:' + theme.searchBorder + ';'}}"
              >
                喜欢
              </view>
            </view>

            <view class="tab-count" style="color: {{theme.mutedText}};">
              {{activeTab === 'all' ? ('共 ' + stories.length + ' 本') : ('共 ' + favoriteStories.length + ' 本')}}
            </view>
          </view>

          <block wx:if="{{activeTab === 'all'}}">
            <view class="grid-list">
              <block wx:for="{{stories}}" wx:key="id">
                <view
                  class="book-item"
                  data-id="{{item.id}}"
                  data-story="{{item}}"
                  data-source="all"
                  bindtap="openBook"
                  bindlongpress="onBookLongPress"
                >
                  <view class="book-cover-wrap">
                    <book-cover
                      title="{{item.displayTitle}}"
                      imageUrl="{{item.ai_cover_url}}"
                      coverStatus="{{item.cover_status}}"
                      themeIndex="{{item.themeIndex}}"
                      size="medium"
                    />
                    <view wx:if="{{item.is_favorite}}" class="favorite-badge">
                      <svg-icon name="heart" color="{{theme.accent}}" size="20rpx" />
                    </view>
                  </view>

                  <view class="book-title" style="color: {{theme.text}};">{{item.displayTitle}}</view>
                </view>
              </block>
            </view>
          </block>

          <block wx:else>
            <block wx:if="{{favoriteStories.length}}">
              <view class="grid-list">
                <block wx:for="{{favoriteStories}}" wx:key="id">
                  <view
                    class="book-item"
                    data-id="{{item.id}}"
                    data-story="{{item}}"
                    data-source="favorite"
                    bindtap="openBook"
                    bindlongpress="onBookLongPress"
                  >
                    <view class="book-cover-wrap">
                      <book-cover
                        title="{{item.displayTitle}}"
                        imageUrl="{{item.ai_cover_url}}"
                        coverStatus="{{item.cover_status}}"
                        themeIndex="{{item.themeIndex}}"
                        size="medium"
                      />
                      <view wx:if="{{item.is_favorite}}" class="favorite-badge">
                        <svg-icon name="heart" color="{{theme.accent}}" size="20rpx" />
                      </view>
                    </view>

                    <view class="book-title" style="color: {{theme.text}};">{{item.displayTitle}}</view>
                  </view>
                </block>
              </view>
            </block>

            <view wx:else class="panel-empty" style="color: {{theme.mutedText}};">还没有喜欢的书</view>
          </block>
        </view>
      </block>
    </view>
  </view>
</view>
