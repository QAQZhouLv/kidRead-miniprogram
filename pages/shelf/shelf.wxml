<view class="page" style="padding: 24rpx;">
  <view style="margin-top: 24rpx;">
    <block wx:if="{{stories.length === 0}}">
      <view style="color:#888;">还没有故事，先去创作一个吧。</view>
    </block>

    <block wx:for="{{stories}}" wx:key="id">
      <view
        data-id="{{item.id}}"
        bindtap="openBook"
        style="margin-top:16rpx;padding:20rpx;background:#fff;border-radius:18rpx;display:flex;gap:20rpx;"
      >
        <image
          src="{{item.display_cover_url}}"
          mode="aspectFill"
          style="width:180rpx;height:240rpx;border-radius:16rpx;background:#eef2f7;flex-shrink:0;"
        />

        <view style="flex:1;min-width:0;">
          <view style="font-size: 30rpx; font-weight: 600;">
            {{item.title}}
          </view>

          <view style="margin-top:8rpx;color:#666;font-size:24rpx;">
            年龄：{{item.age}}
          </view>

          <view style="margin-top:8rpx;color:#999;font-size:22rpx;">
            {{item.cover_status === 'ready' ? '封面已完成' : '封面准备中'}}
          </view>

          <view style="margin-top:8rpx;color:#999;font-size:22rpx;">
            {{item.created_at}}
          </view>
        </view>
      </view>
    </block>
  </view>
</view>