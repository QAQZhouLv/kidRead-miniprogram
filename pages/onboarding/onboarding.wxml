<view class="page onboarding-page {{themeClass}}">
  <view class="sky-bg">
    <view class="cloud cloud-1"></view>
    <view class="cloud cloud-2"></view>
    <view class="star star-1"></view>
    <view class="star star-2"></view>
    <view class="scribble scribble-1"></view>
    <view class="scribble scribble-2"></view>
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
  </view>

  <view class="progress-row">
    <view class="progress-dot {{step >= 0 ? 'active' : ''}}"></view>
    <view class="progress-dot {{step >= 1 ? 'active' : ''}}"></view>
    <view class="progress-dot {{step >= 2 ? 'active' : ''}}"></view>
    <view class="progress-dot {{step >= 3 ? 'active' : ''}}"></view>
    <view class="progress-dot {{step >= 4 ? 'active' : ''}}"></view>
  </view>

  <view class="onboarding-card">
    <block wx:if="{{step === 0}}">
      <view class="hero-illustration">
        <view class="doodle-house"></view>
        <view class="doodle-book"></view>
        <view class="doodle-pencil"></view>
      </view>

      <view class="title">欢迎来到故事的世界</view>
      <view class="desc">在这里，你可以和慧童一起创作、阅读、冒险，还能把自己的想象变成一本真正的小书。</view>

      <view class="primary-btn" bindtap="nextStep">开始认识我吧</view>
    </block>

    <block wx:elif="{{step === 1}}">
      <view class="title">小朋友，你希望我怎么称呼你呀？</view>
      <view class="desc">可以用微信昵称，也可以自己输入。拿不到也没关系，我们先叫你童童。</view>

      <view class="input-wrap">
        <input
          class="text-input"
          value="{{profile.nickname}}"
          placeholder="请输入称呼"
          placeholder-class="input-placeholder"
          maxlength="20"
          bindinput="onNicknameInput"
        />
      </view>

      <view class="btn-row">
        <view wx:if="{{canUseProfileApi}}" class="ghost-btn" bindtap="onGetWechatProfile">
          使用微信昵称
        </view>
      </view>

      <view class="primary-btn" bindtap="confirmNickname">下一步</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>

    <block wx:elif="{{step === 2}}">
      <view class="title">小朋友今年几岁啦？</view>
      <view class="desc">我会根据年龄，和你一起讲更适合你的故事。</view>

      <view class="age-display">{{profile.age}} 岁</view>

      <view class="age-picker-wrap">
        <picker-view
          class="age-picker"
          indicator-style="height: 72rpx;"
          value="{{[ageIndex]}}"
          bindchange="onAgeChange"
        >
          <picker-view-column>
            <view wx:for="{{ageOptions}}" wx:key="*this" class="age-item">
              {{item}} 岁
            </view>
          </picker-view-column>
        </picker-view>
      </view>

      <view class="primary-btn" bindtap="nextStep">下一步</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>

    <block wx:elif="{{step === 3}}">
      <view class="title">选一个你喜欢的颜色吧</view>
      <view class="desc">这个颜色会成为 KidRead 的默认主题，也可以之后在“我的”里再修改。</view>

      <view class="theme-preview-card">
        <view class="preview-cover preview-cover-1"></view>
        <view class="preview-cover preview-cover-2"></view>
        <view class="preview-cover preview-cover-3"></view>
      </view>

      <view class="theme-list">
        <block wx:for="{{themeOptions}}" wx:key="key">
          <view
            class="theme-chip {{profile.themeName === item.key ? 'theme-chip-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onThemeTap"
          >
            {{item.label}}
          </view>
        </block>
      </view>

      <view class="primary-btn" bindtap="nextStep">下一步</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>

    <block wx:else>
      <view class="hero-illustration">
        <view class="doodle-star-big"></view>
      </view>

      <view class="title">接下来，请开始我们的共创旅程吧</view>
      <view class="desc">
        你好，{{profile.nickname || '童童'}}。<text>{{profile.age}}</text> 岁的小小冒险家，现在就出发吧。
      </view>

      <view class="summary-card">
        <view class="summary-row">称呼：{{profile.nickname || '童童'}}</view>
        <view class="summary-row">年龄：{{profile.age}} 岁</view>
        <view class="summary-row">主题：{{profile.themeName}}</view>
      </view>

      <view class="primary-btn" bindtap="completeOnboarding">进入 KidRead</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>
  </view>
</view>