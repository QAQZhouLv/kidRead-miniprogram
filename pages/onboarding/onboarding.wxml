<view class="page {{themeClass}}">
  <!-- STEP 1 -->
  <view wx:if="{{step === 1}}" class="panel panel-theme-bg">
    <view class="skip-inside" bindtap="onSkipAll">跳过全部</view>

    <view class="frame"></view>

    <!-- 第一版装饰：先统一走 flower 结构，后面再替换成 ocean/candy/stars -->
    <view class="corner-flower corner-tl">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="corner-flower corner-tr">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="corner-flower corner-bl">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="corner-flower corner-br">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="content content-center tap-area" bindtap="goStep2">
      <view class="title title-main">欢迎来到故事的世界</view>
      <view class="desc">
        这里有好多好多想象力，等着和你一起<br />变成新的故事。
      </view>
      <view class="tip">轻点一下屏幕，继续下一页</view>
    </view>
  </view>

  <!-- STEP 2 -->
  <view wx:if="{{step === 2}}" class="panel panel-paper-bg">
    <view class="skip-inside" bindtap="onSkipAll">跳过全部</view>

    <view class="decor-cluster decor-step2">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="content content-center">
      <view class="title title-paper">小朋友，<br />你希望我怎么称呼你呢？</view>

      <view class="input-paper">
        <view class="input-label">写下你喜欢的昵称</view>
        <input
          class="name-input"
          maxlength="12"
          placeholder="比如：童童"
          placeholder-class="input-placeholder"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
        <view class="helper">不填写也可以，我会先叫你“小朋友”。</view>
      </view>

      <view class="btn-row">
        <view class="btn btn-paper" bindtap="goStep3">下一步</view>
      </view>
    </view>
  </view>

  <!-- STEP 3 -->
  <view wx:if="{{step === 3}}" class="panel panel-accent-bg">
    <view class="skip-inside" bindtap="onSkipAll">跳过全部</view>

    <view class="decor-cluster decor-step3 flower-warm">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
        <view class="flower-center"></view>
      </view>
    </view>

    <view class="content content-center">
      <view class="title title-contrast">小朋友，你今年几岁啦？</view>

      <view
        class="age-wheel-wrap"
        catchtouchstart="onAgeTouchStart"
        catchtouchmove="onAgeTouchMove"
        catchtouchend="onAgeTouchEnd"
      >
        <view
          class="age-wheel-track {{trackAnimating ? 'age-wheel-track-anim' : ''}}"
          style="transform: translateY({{trackTranslateRpx}}rpx);"
        >
          <view
            wx:for="{{wheelAges}}"
            wx:key="index"
            class="age-row age-row-{{index}} {{item === '' ? 'age-row-empty' : ''}}"
          >
            {{item !== '' ? item + '岁' : ''}}
          </view>
        </view>
      </view>

      <view class="age-hint">上下滑动来选择年龄</view>

      <view class="btn-row">
        <view class="btn btn-primary" bindtap="goStep4">我选好了</view>
      </view>
    </view>
  </view>

  <!-- STEP 4 -->
  <view wx:if="{{step === 4}}" class="panel panel-paper-bg">
    <view class="skip-inside" bindtap="onSkipAll">跳过全部</view>

    <view class="decor-cluster decor-step2">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="content content-center">
      <view class="title title-paper">选一个你喜欢的主题吧！</view>

      <view class="theme-grid">
        <view
          wx:for="{{themeOptions}}"
          wx:key="key"
          class="theme-card {{selectedTheme === item.key ? 'theme-card-active' : ''}}"
          data-theme="{{item.key}}"
          bindtap="onSelectTheme"
        >
          <view class="theme-dot theme-dot-{{item.key}}"></view>
          <view class="theme-label">{{item.label}}</view>
        </view>
      </view>

      <view class="btn-row">
        <view class="btn btn-primary" bindtap="goStep5">下一步</view>
      </view>
    </view>
  </view>

  <!-- STEP 5 -->
  <view wx:if="{{step === 5}}" class="panel panel-theme-bg">
    <view class="frame"></view>

    <view class="corner-flower corner-tl">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="corner-flower corner-tr">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="corner-flower corner-bl">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="corner-flower corner-br">
      <view class="leaf leaf-main"></view>
      <view class="leaf leaf-side"></view>
      <view class="flower">
        <view class="petal petal-top"></view>
        <view class="petal petal-left"></view>
        <view class="petal petal-right"></view>
      </view>
    </view>

    <view class="content content-center">
      <view class="title title-main">让我们开启接下来的旅程吧！</view>

      <view class="finish-text">
        你好呀，<text class="highlight">{{displayName}}</text><br />
        今年 <text class="highlight">{{selectedAge}}</text> 岁，准备出发啦。
      </view>

      <view class="btn-row">
        <view class="btn btn-primary" bindtap="onStartJourney">开始旅程</view>
      </view>
    </view>
  </view>
</view>