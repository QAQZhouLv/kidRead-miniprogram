<view class="page onboarding-page">
  <view class="sky-bg">
    <view class="cloud cloud-1"></view>
    <view class="cloud cloud-2"></view>
    <view class="star star-1"></view>
    <view class="star star-2"></view>
    <view class="scribble scribble-1"></view>
    <view class="scribble scribble-2"></view>
  </view>

  <view class="onboarding-card">
    <block wx:if="{{step === 0}}">
      <view class="hero-illustration">
        <view class="doodle-house"></view>
        <view class="doodle-book"></view>
      </view>

      <view class="title">欢迎来到故事的世界</view>
      <view class="desc">在这里，你可以和慧童一起创作、阅读、冒险。</view>

      <view class="primary-btn" bindtap="nextStep">开始认识我吧</view>
    </block>

    <block wx:elif="{{step === 1}}">
      <view class="title">小朋友，我该怎么称呼你呀？</view>
      <view class="desc">能获取微信昵称就用微信昵称，不能也没关系，我们先叫你童童。</view>

      <view class="input-wrap">
        <input
          class="text-input"
          value="{{profile.nickname}}"
          placeholder="请输入称呼"
          placeholder-class="input-placeholder"
          maxlength="20"
          bindinput="onNicknameInput"
        />
      </view>

      <view class="btn-row">
        <view wx:if="{{canUseProfileApi}}" class="ghost-btn" bindtap="onGetWechatProfile">
          使用微信昵称
        </view>
        <view class="ghost-btn" bindtap="skipWechatProfile">先这样吧</view>
      </view>

      <view class="primary-btn" bindtap="confirmNickname">下一步</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>

    <block wx:elif="{{step === 2}}">
      <view class="title">小朋友今年几岁啦？</view>
      <view class="desc">我会根据年龄，和你一起讲更适合你的故事。</view>

      <view class="age-picker-wrap">
        <picker-view
          class="age-picker"
          indicator-style="height: 72rpx;"
          value="{{[ageIndex]}}"
          bindchange="onAgeChange"
        >
          <picker-view-column>
            <view wx:for="{{ageOptions}}" wx:key="*this" class="age-item">
              {{item}} 岁
            </view>
          </picker-view-column>
        </picker-view>
      </view>

      <view class="primary-btn" bindtap="nextStep">下一步</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>

    <block wx:else>
      <view class="hero-illustration">
        <view class="doodle-star-big"></view>
      </view>

      <view class="title">接下来，请开始我们的共创旅程吧</view>
      <view class="desc">
        你好，{{profile.nickname || '童童'}}。<text>{{profile.age}}</text> 岁的冒险，现在开始啦。
      </view>

      <view class="primary-btn" bindtap="completeOnboarding">进入 KidRead</view>
      <view class="link-btn" bindtap="prevStep">上一步</view>
    </block>
  </view>
</view>