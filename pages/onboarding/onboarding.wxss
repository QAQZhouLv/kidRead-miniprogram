.page {
  min-height: 100vh;
}

.onboarding-page {
  position: relative;
  overflow: hidden;
  padding: 48rpx 28rpx 60rpx;
  box-sizing: border-box;
}

.theme-sky {
  background: linear-gradient(180deg, #fffaf1 0%, #f1f9ff 100%);
}

.theme-peach {
  background: linear-gradient(180deg, #fff7f1 0%, #fff1ec 100%);
}

.theme-mint {
  background: linear-gradient(180deg, #f8fff9 0%, #effff8 100%);
}

.sky-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.progress-row {
  position: relative;
  z-index: 2;
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
  gap: 14rpx;
}

.progress-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(140, 155, 180, 0.25);
  transition: all 0.25s ease;
}

.theme-sky .progress-dot.active {
  width: 36rpx;
  border-radius: 999rpx;
  background: #7db6ff;
}

.theme-peach .progress-dot.active {
  width: 36rpx;
  border-radius: 999rpx;
  background: #ffb38a;
}

.theme-mint .progress-dot.active {
  width: 36rpx;
  border-radius: 999rpx;
  background: #78d7be;
}

.onboarding-card {
  position: relative;
  z-index: 2;
  margin-top: 46rpx;
  padding: 40rpx 30rpx 36rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 20rpx 50rpx rgba(63, 96, 140, 0.1);
  backdrop-filter: blur(8rpx);
}

.title {
  font-size: 42rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #2b3550;
  text-align: center;
}

.desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #7f8aa2;
  text-align: center;
}

.hero-illustration {
  height: 220rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.doodle-house,
.doodle-book,
.doodle-pencil,
.doodle-star-big {
  position: absolute;
  animation: wobbleFloat 2.8s ease-in-out infinite;
}

.doodle-house {
  width: 190rpx;
  height: 140rpx;
  left: 50%;
  top: 24rpx;
  margin-left: -95rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #ffd79c 0%, #ffe9c2 100%);
  box-shadow: 0 10rpx 24rpx rgba(255, 200, 110, 0.18);
}

.doodle-book {
  width: 128rpx;
  height: 90rpx;
  left: 50%;
  bottom: 20rpx;
  margin-left: -64rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #a8d8ff 0%, #d7f1ff 100%);
  transform: rotate(-8deg);
}

.doodle-pencil {
  width: 42rpx;
  height: 150rpx;
  right: 110rpx;
  top: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffb48c 0%, #ffd8bf 100%);
  transform: rotate(18deg);
}

.doodle-star-big {
  width: 150rpx;
  height: 150rpx;
  left: 50%;
  top: 24rpx;
  margin-left: -75rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffe08f 0%, #fff1bf 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 213, 95, 0.2);
}

.input-wrap {
  margin-top: 28rpx;
  background: #ffffff;
  border: 2rpx solid #e7edf8;
  border-radius: 22rpx;
  padding: 0 20rpx;
}

.text-input {
  height: 88rpx;
  font-size: 30rpx;
  color: #2b3550;
}

.input-placeholder {
  color: #b3bdd0;
}

.btn-row {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.primary-btn,
.ghost-btn {
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.theme-sky .primary-btn {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #7db6ff 0%, #9dd8ff 100%);
  color: #ffffff;
}

.theme-peach .primary-btn {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #ffb28c 0%, #ffd1b9 100%);
  color: #ffffff;
}

.theme-mint .primary-btn {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #78d7be 0%, #b6f0df 100%);
  color: #ffffff;
}

.ghost-btn {
  flex: 1;
  background: #f4f7fd;
  color: #6c7a96;
}

.link-btn {
  margin-top: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8ea0bd;
}

.age-display {
  margin-top: 22rpx;
  text-align: center;
  font-size: 46rpx;
  font-weight: 700;
  color: #31405d;
}

.age-picker-wrap {
  margin-top: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  padding: 10rpx 0;
  border: 2rpx solid #e7edf8;
}

.age-picker {
  width: 100%;
  height: 240rpx;
}

.age-item {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 34rpx;
  color: #2f3c58;
}

.theme-preview-card {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  gap: 14rpx;
  justify-content: center;
}

.preview-cover {
  width: 120rpx;
  height: 156rpx;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 18rpx rgba(50, 74, 110, 0.08);
}

.theme-sky .preview-cover-1,
.theme-sky .preview-cover-2,
.theme-sky .preview-cover-3 {
  background: linear-gradient(135deg, #8fc5ff 0%, #b9e2ff 100%);
}

.theme-peach .preview-cover-1,
.theme-peach .preview-cover-2,
.theme-peach .preview-cover-3 {
  background: linear-gradient(135deg, #ffbca2 0%, #ffe1d2 100%);
}

.theme-mint .preview-cover-1,
.theme-mint .preview-cover-2,
.theme-mint .preview-cover-3 {
  background: linear-gradient(135deg, #86dfc6 0%, #d7fff2 100%);
}

.theme-list {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.theme-chip {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #f4f7fd;
  color: #6d7a92;
  font-size: 24rpx;
}

.theme-sky .theme-chip-active {
  background: linear-gradient(135deg, #7db6ff 0%, #9dd8ff 100%);
  color: #ffffff;
}

.theme-peach .theme-chip-active {
  background: linear-gradient(135deg, #ffb28c 0%, #ffd1b9 100%);
  color: #ffffff;
}

.theme-mint .theme-chip-active {
  background: linear-gradient(135deg, #78d7be 0%, #b6f0df 100%);
  color: #ffffff;
}

.summary-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
}

.summary-row {
  font-size: 26rpx;
  color: #58647d;
  line-height: 1.8;
}

.cloud,
.star,
.scribble,
.circle {
  position: absolute;
}

.cloud {
  background: rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  animation: sway 3.8s ease-in-out infinite;
}

.cloud-1 {
  width: 180rpx;
  height: 70rpx;
  left: 40rpx;
  top: 100rpx;
}

.cloud-2 {
  width: 220rpx;
  height: 80rpx;
  right: 20rpx;
  top: 220rpx;
  animation-delay: 0.8s;
}

.star {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffe08a;
  animation: pulseTiny 2.4s ease-in-out infinite;
}

.star-1 {
  left: 100rpx;
  top: 260rpx;
}

.star-2 {
  right: 120rpx;
  top: 140rpx;
  animation-delay: 1.1s;
}

.scribble {
  border: 4rpx solid rgba(255, 174, 122, 0.45);
  border-radius: 999rpx;
  animation: sway 4.2s ease-in-out infinite;
}

.scribble-1 {
  width: 140rpx;
  height: 40rpx;
  left: 30rpx;
  bottom: 220rpx;
  transform: rotate(-8deg);
}

.scribble-2 {
  width: 120rpx;
  height: 36rpx;
  right: 40rpx;
  bottom: 320rpx;
  transform: rotate(10deg);
}

.circle {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  animation: sway 5s ease-in-out infinite;
}

.circle-1 {
  width: 180rpx;
  height: 180rpx;
  right: -20rpx;
  top: 360rpx;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  left: -20rpx;
  bottom: 240rpx;
}

@keyframes sway {
  0%, 100% {
    transform: translateY(0) translateX(0);
  }
  50% {
    transform: translateY(-8rpx) translateX(4rpx);
  }
}

@keyframes pulseTiny {
  0%, 100% {
    transform: scale(1);
    opacity: 0.85;
  }
  50% {
    transform: scale(1.15);
    opacity: 1;
  }
}

@keyframes wobbleFloat {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  25% {
    transform: translateY(-4rpx) rotate(-1deg);
  }
  50% {
    transform: translateY(-8rpx) rotate(1deg);
  }
  75% {
    transform: translateY(-4rpx) rotate(-1deg);
  }
}