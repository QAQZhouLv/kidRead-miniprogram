page {
  height: 100%;
  background: var(--theme-bg, #f3fbef);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  background: var(--theme-bg, #f3fbef);
  padding: 0;
  box-sizing: border-box;
  display: flex;
  align-items: stretch;
  justify-content: center;
}

/* ===== 主题变量 ===== */

.theme-meadow {
  --theme-primary: #58B368;
  --theme-secondary: #A8E6A3;
  --theme-accent: #FF9F43;
  --theme-warm: #FFE66D;
  --theme-bg: #F3FBEF;
  --theme-paper: #FFFFFF;
  --theme-text: #2E5D3B;
  --theme-contrast: #FFF8EC;
}

.theme-ocean {
  --theme-primary: #4DA6FF;
  --theme-secondary: #BFE4FF;
  --theme-accent: #FF7A59;
  --theme-warm: #FFD166;
  --theme-bg: #EAF6FF;
  --theme-paper: #FFFFFF;
  --theme-text: #2B4F73;
  --theme-contrast: #FFF8F0;
}

.theme-berry {
  --theme-primary: #FF6B81;
  --theme-secondary: #FFC2C7;
  --theme-accent: #7B6CF6;
  --theme-warm: #FFE66D;
  --theme-bg: #FFF1F3;
  --theme-paper: #FFFFFF;
  --theme-text: #6B2E3A;
  --theme-contrast: #FFF7FA;
}

.theme-sunny {
  --theme-primary: #FFC93C;
  --theme-secondary: #FFF3B0;
  --theme-accent: #FF6B4A;
  --theme-warm: #4D96FF;
  --theme-bg: #FFF9E6;
  --theme-paper: #FFFFFF;
  --theme-text: #6E4C1E;
  --theme-contrast: #FFF8EE;
}

.theme-citrus {
  --theme-primary: #FF8C42;
  --theme-secondary: #FFD166;
  --theme-accent: #4D96FF;
  --theme-warm: #6EE7B7;
  --theme-bg: #FFF4E8;
  --theme-paper: #FFFFFF;
  --theme-text: #6A3B1A;
  --theme-contrast: #FFF8EE;
}

.theme-dream {
  --theme-primary: #8B7CF6;
  --theme-secondary: #D7D2FF;
  --theme-accent: #FF9BD2;
  --theme-warm: #FFE66D;
  --theme-bg: #F4F2FF;
  --theme-paper: #FFFFFF;
  --theme-text: #3D3A70;
  --theme-contrast: #FFF8FF;
}

/* ===== 基础面板 ===== */

.panel {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  border-radius: 0;
  box-shadow: none;
}

.panel-theme-bg {
  background: var(--theme-bg);
}

.panel-paper-bg {
  background: var(--theme-paper);
}

.panel-accent-bg {
  background: var(--theme-accent);
}

.skip-inside {
  position: absolute;
  left: 24rpx;
  top: 96rpx;
  z-index: 30;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: var(--theme-text);
  font-size: 26rpx;
  line-height: 1;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.frame {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  top: 78rpx;
  bottom: 42rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 12rpx;
  z-index: 1;
  animation: frameBreath 4.2s ease-in-out infinite;
}

.content {
  position: relative;
  z-index: 5;
  min-height: 100vh;
  padding: 180rpx 56rpx 120rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  animation: contentFadeUp 0.5s ease both;
}

.content-center {
  justify-content: center;
}

.tap-area {
  width: 100%;
}

.title {
  font-weight: 700;
  line-height: 1.34;
  letter-spacing: 1rpx;
  animation: titleBreath 3.2s ease-in-out infinite;
}

.title-main {
  color: var(--theme-primary);
  font-size: 74rpx;
}

.title-paper {
  color: var(--theme-text);
  font-size: 62rpx;
}

.title-contrast {
  color: var(--theme-contrast);
  font-size: 62rpx;
}

.desc {
  margin-top: 56rpx;
  max-width: 620rpx;
  font-size: 32rpx;
  line-height: 1.95;
  color: var(--theme-text);
  animation: softFloat 3.8s ease-in-out infinite;
}

.theme-grid {
  width: 100%;
  max-width: 620rpx;
  margin-top: 40rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
}

.theme-card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  padding: 26rpx 20rpx;
  box-sizing: border-box;
  border: 4rpx solid transparent;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.theme-card-active {
  border-color: var(--theme-primary);
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.08);
}

.theme-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.theme-label {
  font-size: 28rpx;
  color: var(--theme-text);
  line-height: 1.4;
}

.theme-dot-meadow { background: #58B368; }
.theme-dot-ocean  { background: #4DA6FF; }
.theme-dot-berry  { background: #FF6B81; }
.theme-dot-sunny  { background: #FFC93C; }
.theme-dot-citrus { background: #FF8C42; }
.theme-dot-dream  { background: #8B7CF6; }

.tip {
  margin-top: 82rpx;
  font-size: 30rpx;
  color: rgba(53, 85, 58, 0.72);
  animation: tipBlink 2.4s ease-in-out infinite;
}

.btn-row {
  margin-top: 56rpx;
  display: flex;
  justify-content: center;
}

.btn {
  min-width: 220rpx;
  padding: 24rpx 38rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  text-align: center;
  animation: buttonFloat 2.8s ease-in-out infinite;
}

.btn-primary {
  background: var(--theme-primary);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.12);
}

.btn-paper {
  background: var(--theme-secondary);
  color: var(--theme-text);
}

.input-paper {
  width: 100%;
  max-width: 580rpx;
  margin-top: 52rpx;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.08);
  text-align: left;
  transform: rotate(-1deg);
  animation: cardBreath 3.8s ease-in-out infinite;
}

.input-label {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
}

.name-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 46rpx;
  color: var(--theme-text);
  border-bottom: 4rpx solid rgba(0, 0, 0, 0.12);
}

.input-placeholder {
  color: #b1ad9e;
}

.helper {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #8a846f;
}

/* ===== 年龄滚轮 ===== */

.age-wheel-wrap {
  position: relative;
  width: 220rpx;
  height: 258rpx;
  margin-top: 28rpx;
  overflow: hidden;
  user-select: none;
}

.age-wheel-track {
  width: 100%;
}

.age-wheel-track-anim {
  transition: transform 0.2s ease;
}

.age-row {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  text-align: center;
  color: var(--theme-contrast);
}

.age-row-0,
.age-row-4 {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.16);
  transform: scale(0.72);
}

.age-row-1,
.age-row-3 {
  font-size: 42rpx;
  color: rgba(255, 255, 255, 0.66);
  transform: scale(0.86);
}

.age-row-2 {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--theme-contrast);
  transform: scale(1);
}

.age-row-empty {
  opacity: 0;
}

.age-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
  animation: softFloat 3.2s ease-in-out infinite;
}

/* ===== 装饰 ===== */

.corner-flower,
.decor-cluster {
  position: absolute;
  width: 150rpx;
  height: 150rpx;
  z-index: 2;
}

.corner-flower .leaf,
.decor-cluster .leaf {
  position: absolute;
  background: var(--theme-primary);
  border-radius: 100% 0 100% 0 / 70% 0 100% 30%;
}

.corner-flower .leaf-main,
.decor-cluster .leaf-main {
  width: 88rpx;
  height: 40rpx;
  left: 0;
  top: 16rpx;
  transform: rotate(-12deg);
  animation: leafSwingA 4.2s ease-in-out infinite;
  transform-origin: 70% 50%;
}

.corner-flower .leaf-side,
.decor-cluster .leaf-side {
  width: 42rpx;
  height: 100rpx;
  left: -8rpx;
  top: 42rpx;
  transform: rotate(-28deg);
  animation: leafSwingB 4.8s ease-in-out infinite;
  transform-origin: 50% 85%;
}

.corner-flower .flower,
.decor-cluster .flower {
  position: absolute;
  left: 34rpx;
  top: 42rpx;
  width: 72rpx;
  height: 72rpx;
  animation: flowerBreath 3.6s ease-in-out infinite;
  transform-origin: center center;
}

.petal {
  position: absolute;
  width: 30rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 70% 70% 70% 70% / 80% 80% 50% 50%;
}

.petal-top {
  left: 21rpx;
  top: 0;
}

.petal-left {
  left: 3rpx;
  top: 22rpx;
  transform: rotate(-80deg);
}

.petal-right {
  left: 39rpx;
  top: 22rpx;
  transform: rotate(80deg);
}

.flower-warm .petal {
  background: var(--theme-warm);
}

.flower-center {
  position: absolute;
  left: 24rpx;
  top: 22rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--theme-accent);
}

.corner-tl {
  left: 18rpx;
  top: 92rpx;
}

.corner-tr {
  right: 18rpx;
  top: 122rpx;
  transform: scaleX(-1);
}

.corner-bl {
  left: 18rpx;
  bottom: 30rpx;
  transform: scaleY(-1);
}

.corner-br {
  right: 18rpx;
  bottom: 30rpx;
  transform: scale(-1, -1);
}

.decor-step2 {
  right: 26rpx;
  top: 122rpx;
  transform: scaleX(-1);
}

.decor-step3 {
  right: 20rpx;
  top: 122rpx;
  transform: scaleX(-1);
}

.finish-text {
  margin-top: 42rpx;
  max-width: 560rpx;
  font-size: 36rpx;
  line-height: 1.9;
  color: var(--theme-text);
  animation: softFloat 3.6s ease-in-out infinite;
}

.highlight {
  color: var(--theme-primary);
  font-weight: 700;
}

/* ===== 动画 ===== */

@keyframes contentFadeUp {
  0% {
    opacity: 0;
    transform: translateY(18rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes flowerBreath {
  0%, 100% {
    transform: scale(1) rotate(0deg);
  }
  50% {
    transform: scale(1.035) rotate(1.2deg);
  }
}

@keyframes leafSwingA {
  0%, 100% {
    transform: rotate(-12deg);
  }
  50% {
    transform: rotate(-7deg);
  }
}

@keyframes leafSwingB {
  0%, 100% {
    transform: rotate(-28deg);
  }
  50% {
    transform: rotate(-22deg);
  }
}

@keyframes titleBreath {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.018);
  }
}

@keyframes cardBreath {
  0%, 100% {
    transform: rotate(-1deg) scale(1);
  }
  50% {
    transform: rotate(-1deg) scale(1.01);
  }
}

@keyframes buttonFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
}

@keyframes softFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-3rpx);
  }
}

@keyframes tipBlink {
  0%, 100% {
    opacity: 0.75;
  }
  50% {
    opacity: 1;
  }
}

@keyframes frameBreath {
  0%, 100% {
    opacity: 0.82;
  }
  50% {
    opacity: 0.92;
  }
}