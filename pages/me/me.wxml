<view class="page me-page {{themeClass}}">
  <view class="profile-card">
    <view class="profile-bubbles bubble-1"></view>
    <view class="profile-bubbles bubble-2"></view>

    <view class="avatar-wrap">
      <image
        wx:if="{{profile.avatarUrl}}"
        class="avatar"
        src="{{profile.avatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="avatar avatar-default">
        {{profile.avatarText}}
      </view>
    </view>

    <view class="profile-main">
      <view class="profile-name">{{profile.nickname || '童童'}}</view>
      <view class="profile-sub">{{profile.age}} 岁 · KidRead 小朋友</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">个人资料</view>

    <view class="field-block">
      <view class="field-label">称呼</view>
      <input
        class="field-input"
        value="{{profile.nickname}}"
        maxlength="20"
        placeholder="请输入称呼"
        bindinput="onNicknameInput"
      />
      <view class="save-btn" bindtap="saveNickname">保存称呼</view>
    </view>

    <view class="field-block">
      <view class="field-label">年龄</view>
      <picker
        mode="selector"
        range="{{ageOptions}}"
        value="{{profile.age - 1}}"
        bindchange="onAgeChange"
      >
        <view class="picker-display">{{profile.age}} 岁</view>
      </picker>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">阅读与互动</view>

    <view class="setting-row">
      <view class="setting-label">自动朗读</view>
      <switch checked="{{profile.autoReadEnabled}}" bindchange="onAutoReadChange" />
    </view>

    <view class="field-block">
      <view class="field-label">主题色</view>
      <view class="theme-list">
        <block wx:for="{{themeOptions}}" wx:key="key">
          <view
            class="theme-chip {{profile.themeName === item.key ? 'theme-chip-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onThemeTap"
          >
            {{item.label}}
          </view>
        </block>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">阅读模式</view>
      <view class="mode-list">
        <block wx:for="{{readingModes}}" wx:key="key">
          <view
            class="mode-chip {{profile.readingMode === item.key ? 'mode-chip-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onReadingModeTap"
          >
            {{item.label}}
          </view>
        </block>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">字体大小</view>
      <view class="mode-list">
        <block wx:for="{{fontScales}}" wx:key="key">
          <view
            class="mode-chip {{profile.fontScale === item.key ? 'mode-chip-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onFontScaleTap"
          >
            {{item.label}}
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">帮助与系统</view>

    <view class="action-btn" bindtap="onOpenOnboardingNow">再看一次欢迎引导</view>
    <view class="action-btn action-btn-soft" bindtap="onResetOnboarding">重置首次进入状态</view>
  </view>
</view>