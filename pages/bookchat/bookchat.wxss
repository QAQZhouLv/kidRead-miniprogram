.page {
  box-sizing: border-box;
  background: #f7f7f7;
  min-height: 100vh;
}

.custom-nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 24rpx;
  padding-right: 24rpx;
  background: rgba(247, 247, 247, 0.96);
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
}

.nav-side {
  width: 96rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.nav-title {
  max-width: 320rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
}

.nav-back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  line-height: 1;
  color: #333;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.nav-bell {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.nav-bell-on {
  background: #eff5ff;
  border: 2rpx solid #d5e6ff;
}

.nav-bell-off {
  background: #ffffff;
  border: 2rpx solid #e6e6e6;
}

.nav-bell-image {
  width: 38rpx;
  height: 38rpx;
}

.page-content {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.book-title {
  font-size: 40rpx;
  font-weight: 700;
}

.book-meta {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.book-preview {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.preview-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.preview-scroll {
  max-height: 30vh;
}

.preview-scroll-inner {
  min-height: 0;
  display: block;
}

.preview-content {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  color: #333;
}

.draft-preview {
  background: #fff7e8;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.draft-title {
  font-size: 26rpx;
  color: #c57a00;
  margin-bottom: 10rpx;
}

.draft-content {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  color: #7a4b00;
}

.chat-list {
  margin-top: 10rpx;
}

.draft-bubble-wrap {
  position: fixed;
  bottom: 160rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 80;
}

.draft-bubble {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  border: 2rpx dashed #ddd;
  color: #333;
}

.archive-wrap {
  position: fixed;
  right: 24rpx;
  bottom: 140rpx;
  z-index: 90;
}

.archive-btn {
  min-width: 140rpx;
  background: #fff7e8;
  color: #a86500;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.25);
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-panel {
  width: 80%;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 600;
}

.edit-close {
  font-size: 36rpx;
  color: #999;
}

.edit-body {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.edit-input {
  flex: 1;
  border-bottom: 2rpx solid #ddd;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.edit-confirm {
  margin-left: 20rpx;
  font-size: 34rpx;
  color: #1677ff;
}
