
.page {
  box-sizing: border-box;
  min-height: 100vh;
}

.custom-nav {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  top: 10rpx;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 18rpx;
  padding-right: 18rpx;
  border-radius: 32rpx;
  backdrop-filter: blur(12rpx);
  box-sizing: content-box;
  box-shadow: 0 14rpx 34rpx rgba(81, 67, 44, 0.08);
}

.nav-side {
  width: 96rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 0;
}

.nav-title {
  max-width: 320rpx;
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-back,
.nav-bell {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.nav-back {
  font-size: 50rpx;
  background: rgba(255,255,255,0.8);
}

.nav-bell {
  border: 3rpx solid transparent;
}

.nav-bell-off { opacity: 0.82; }

.page-content {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.page-header,
.book-preview,
.draft-preview,
.chat-list {
  border-radius: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(81, 67, 44, 0.05);
}

.page-header {
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.book-title {
  font-size: 40rpx;
  font-weight: 700;
}

.book-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.book-preview {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.preview-title,
.draft-title {
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.preview-scroll {
  max-height: 30vh;
  padding: 12rpx 0 4rpx;
}

.preview-content,
.draft-content {
  font-size: 28rpx;
  line-height: 1.95;
  white-space: pre-wrap;
  text-indent: 2em;
}

.draft-preview {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.chat-list {
  margin-top: 8rpx;
  padding: 18rpx;
}

.draft-bubble-wrap {
  position: fixed;
  bottom: 178rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 80;
}

.draft-bubble {
  border-radius: 28rpx;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  border: 3rpx dashed rgba(130, 118, 98, 0.22);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.04);
}

.archive-wrap {
  position: fixed;
  right: 24rpx;
  bottom: 144rpx;
  z-index: 90;
}

.archive-btn {
  width: 136rpx;
  min-width: 136rpx;
  height: 72rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  color: #fff !important;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;

  display: flex;
  align-items: center;
  justify-content: center;

  line-height: 1;
  box-sizing: border-box;

  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.1);
}

.archive-btn::after {
  border: none;
}

.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(52, 40, 27, 0.22);
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-panel {
  width: 84%;
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 700;
}

.edit-close,
.edit-confirm {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
}

.edit-body {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
}

.edit-input {
  flex: 1;
  min-height: 76rpx;
  border-bottom: 3rpx solid rgba(111, 101, 86, 0.18);
  font-size: 30rpx;
}

.edit-confirm {
  margin-left: 18rpx;
}
