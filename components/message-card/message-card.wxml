<view class="msg-wrap {{message.role === 'user' ? 'user-wrap' : 'assistant-wrap'}}">
  <block wx:if="{{message.role === 'user'}}">
    <view class="user-bubble">
      {{message.text}}
    </view>
  </block>

  <block wx:else>
    <view class="assistant-card">
      <view
        wx:if="{{normalizedLead}}"
        class="section-block lead-block {{ttsEnabled ? 'section-block-enabled' : 'section-block-disabled'}}"
        data-section="lead"
        data-text="{{normalizedLead}}"
        bindtap="onSectionTap"
      >
        <text class="lead-text">{{normalizedLead}}</text>
      </view>

      <view
        wx:if="{{normalizedStory}}"
        class="section-block story-block {{ttsEnabled ? 'section-block-enabled' : 'section-block-disabled'}}"
        data-section="story"
        data-text="{{normalizedStory}}"
        bindtap="onSectionTap"
      >
        <text class="story-fallback">{{normalizedStory}}</text>
      </view>

      <view
        wx:if="{{normalizedGuide}}"
        class="section-block guide-block {{ttsEnabled ? 'section-block-enabled' : 'section-block-disabled'}}"
        data-section="guide"
        data-text="{{normalizedGuide}}"
        bindtap="onSectionTap"
      >
        <text class="lead-text">{{normalizedGuide}}</text>
      </view>

      <view wx:if="{{normalizedChoices.length}}" class="choices-wrap">
        <view
          wx:for="{{normalizedChoices}}"
          wx:key="*this"
          class="choice-btn"
          data-choice="{{item}}"
          bindtap="onChoiceTap"
        >
          {{item}}
        </view>
      </view>
    </view>
  </block>
</view>