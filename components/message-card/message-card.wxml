<view class="msg-wrap {{renderMessage.role === 'user' ? 'user-wrap' : 'assistant-wrap'}}">
  <block wx:if="{{renderMessage.role === 'user'}}">
    <view class="user-bubble">
      {{renderMessage.text}}
    </view>
  </block>

  <block wx:else>
    <view class="assistant-card">
      <view
        wx:if="{{renderMessage.leadText}}"
        class="section-block lead-block {{playingMessageId === renderMessage.id && playingSection === 'lead' ? 'section-block-playing' : ''}} {{ttsEnabled ? 'section-block-enabled' : 'section-block-disabled'}}"
        data-section="lead"
        bindtap="onSectionTap"
      >
        <view class="lead-text">
          <block wx:if="{{renderMessage.leadSentences && renderMessage.leadSentences.length}}">
            <text
              wx:for="{{renderMessage.leadSentences}}"
              wx:key="index"
              id="sent-{{renderMessage.id}}-lead-{{index}}"
              class="sentence {{playingMessageId === renderMessage.id && playingSection === 'lead' && playingSentenceIndex === index ? 'playing-sentence' : ''}}"
            >
              {{item}}
            </text>
          </block>
          <text wx:else>{{renderMessage.leadText}}</text>
        </view>
      </view>

      <view
        wx:if="{{renderMessage.storyText}}"
        class="section-block story-block {{playingMessageId === renderMessage.id && playingSection === 'story' ? 'section-block-playing' : ''}} {{ttsEnabled ? 'section-block-enabled' : 'section-block-disabled'}}"
        data-section="story"
        bindtap="onSectionTap"
      >
        <block wx:if="{{renderMessage.storyParagraphs && renderMessage.storyParagraphs.length}}">
          <view wx:for="{{renderMessage.storyParagraphs}}" wx:key="index" class="story-paragraph">
            <block wx:for="{{item.sentences}}" wx:key="index" wx:for-item="sentence">
              <text
                id="sent-{{renderMessage.id}}-story-{{sentence.index}}"
                class="sentence-text story-sentence {{playingMessageId === renderMessage.id && playingSection === 'story' && playingSentenceIndex === sentence.index ? 'sentence-text-playing' : ''}}"
              >
                {{sentence.text}}
              </text>
            </block>
          </view>
        </block>
        <text wx:else class="story-fallback">{{renderMessage.storyText}}</text>
      </view>

      <view
        wx:if="{{renderMessage.guideText}}"
        class="section-block guide-block {{playingMessageId === renderMessage.id && playingSection === 'guide' ? 'section-block-playing' : ''}} {{ttsEnabled ? 'section-block-enabled' : 'section-block-disabled'}}"
        data-section="guide"
        bindtap="onSectionTap"
      >
        <block wx:for="{{renderMessage.guideSentences || []}}" wx:key="index">
          <text
            id="sent-{{renderMessage.id}}-guide-{{index}}"
            class="sentence-text {{playingMessageId === renderMessage.id && playingSection === 'guide' && playingSentenceIndex === index ? 'sentence-text-playing' : ''}}"
          >
            {{item}}
          </text>
        </block>
      </view>

      <view wx:if="{{normalizedChoices.length}}" class="choices-wrap">
        <view
          wx:for="{{normalizedChoices}}"
          wx:key="*this"
          class="choice-btn"
          data-text="{{item}}"
          bindtap="onChoiceTap"
        >
          {{item}}
        </view>
      </view>
    </view>
  </block>
</view>