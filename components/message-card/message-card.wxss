
.msg-wrap {
  display: flex;
  margin-bottom: 22rpx;
}

.user-wrap {
  justify-content: flex-end;
}

.assistant-wrap {
  justify-content: flex-start;
}

.user-bubble {
  max-width: 74%;
  background: #f2d98b;
  color: #5f4b1d;
  border-radius: 28rpx 28rpx 10rpx 28rpx;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  line-height: 1.72;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.04);
}

.assistant-card {
  max-width: 88%;
  background: rgba(255, 253, 246, 0.96);
  border-radius: 30rpx;
  padding: 20rpx;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-block {
  border-radius: 22rpx;
  padding: 12rpx 14rpx;
  transition: all 0.2s ease;
}

.section-block + .section-block {
  margin-top: 10rpx;
}

.section-block-enabled {
  border: 2rpx solid transparent;
}

.section-block-disabled {
  opacity: 0.92;
}

.section-block-playing {
  background: #fff7dc;
  border-color: #efd05a;
}

.lead-block {
  background: #f7f1e4;
  font-size: 26rpx;
  color: #7c6f5d;
  line-height: 1.76;
}

.guide-block {
  background: #f5efe2;
  font-size: 26rpx;
  color: #8b7d69;
  line-height: 1.76;
}

.story-block {
  background: #fff2c7;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.95;
  color: #3f382f;
}

.story-paragraph {
  margin-bottom: 22rpx;
  text-indent: 2em;
  line-height: 1.95;
}

.story-paragraph:last-child {
  margin-bottom: 0;
}

.story-fallback {
  display: block;
  line-height: 1.95;
  white-space: pre-wrap;
  text-indent: 2em;
}

.sentence-text {
  display: inline;
  line-height: 1.85;
  border-bottom: 4rpx dashed transparent;
}

.story-sentence {
  color: #3f382f;
}

.sentence-text-playing {
  border-bottom-color: #d7ab24;
}

.sentence {
  line-height: 1.8;
}

.playing-sentence {
  border-bottom: 4rpx dashed #d7ab24;
}

.pending-text {
  font-size: 24rpx;
  color: #aaa08e;
  margin-top: 8rpx;
}

.choices-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.choice-btn {
  background: #fff8e6;
  border-radius: 999rpx;
  border: 2rpx solid #f0db95;
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  color: #7a6034;
}
