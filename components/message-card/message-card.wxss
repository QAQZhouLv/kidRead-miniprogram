.msg-wrap {
  display: flex;
  margin-bottom: 22rpx;
}

.user-wrap {
  justify-content: flex-end;
}

.assistant-wrap {
  justify-content: flex-start;
}

.user-bubble {
  max-width: 74%;
  background: #f2d98b;
  color: #5f4b1d;
  border-radius: 28rpx 28rpx 10rpx 28rpx;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  line-height: 1.72;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.04);
}

/* 只去掉外层总卡片，不动结构 */
.assistant-card {
  max-width: 88%;
  background: transparent;
  border-radius: 0;
  padding: 0;
  box-shadow: none;
}

/* 把每个 section 直接做成独立聊天框 */
.section-block {
  display: block;
  width: fit-content;
  max-width: 100%;
  border-radius: 28rpx 28rpx 28rpx 10rpx;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.04);
}

.section-block + .section-block {
  margin-top: 12rpx;
}

.section-block-enabled {
  border: 2rpx solid transparent;
}

.section-block-disabled {
  opacity: 1;
}

.section-block-playing {
  border-color: #efd05a;
  background: #fff7dc !important;
}

.lead-block,
.guide-block {
  background: rgba(255, 253, 246, 0.96);
  font-size: 30rpx;
  color: #5c4b2e;
  line-height: 1.9;
}

.story-block {
  background: rgba(255, 253, 246, 0.96);
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.95;
  color: #3f382f;
}

.story-paragraph {
  margin-bottom: 22rpx;
  text-indent: 2em;
  line-height: 1.95;
}

.story-paragraph:last-child {
  margin-bottom: 0;
}

.story-fallback {
  display: block;
  line-height: 1.95;
  white-space: pre-wrap;
  text-indent: 2em;
}

.sentence-text {
  display: inline;
  line-height: 1.85;
  border-bottom: 4rpx dashed transparent;
}

.story-sentence {
  color: #3f382f;
}

.sentence-text-playing {
  border-bottom-color: #d7ab24;
}

.lead-inline-flow {
  display: inline;
  font-size: inherit;
  line-height: inherit;
  color: inherit;
}

.pending-text {
  font-size: 24rpx;
  color: #aaa08e;
  margin-top: 8rpx;
}

.choices-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.choice-btn {
  background: #fff8e6;
  border-radius: 999rpx;
  border: 2rpx solid #f0db95;
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  color: #7a6034;
}