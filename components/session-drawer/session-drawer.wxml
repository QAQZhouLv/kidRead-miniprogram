<view wx:if="{{visible}}">
  <view
    class="drawer-mask"
    style="top: {{offsetTop}}px;"
    bindtap="onMaskTap"
  ></view>

  <view
    class="drawer"
    style="top: {{offsetTop}}px;"
  >
    <view class="drawer-header">
      <view class="drawer-title">{{title}}</view>
      <button bindtap="onNewTap">新对话</button>
    </view>

    <scroll-view scroll-y class="drawer-list">
      <block wx:if="{{pinnedSessions.length}}">
        <view class="drawer-group-title">置顶</view>
        <block wx:for="{{pinnedSessions}}" wx:key="session_id">
          <view
            class="drawer-item {{item.session_id === currentSessionId ? 'drawer-item-active' : ''}}"
            data-sessionid="{{item.session_id}}"
            bindtap="onSessionTap"
          >
            <view class="drawer-item-main">
              <view class="drawer-item-title">{{item.title || '新对话'}}</view>
            </view>

            <view
              class="drawer-more-btn"
              data-session="{{item}}"
              catchtap="onMoreTap"
            >···</view>
          </view>
        </block>
      </block>

      <view class="drawer-group-title">最近</view>
      <block wx:if="{{normalSessions.length}}">
        <block wx:for="{{normalSessions}}" wx:key="session_id">
          <view
            class="drawer-item {{item.session_id === currentSessionId ? 'drawer-item-active' : ''}}"
            data-sessionid="{{item.session_id}}"
            bindtap="onSessionTap"
          >
            <view class="drawer-item-main">
              <view class="drawer-item-title">{{item.title || '新对话'}}</view>
            </view>

            <view
              class="drawer-more-btn"
              data-session="{{item}}"
              catchtap="onMoreTap"
            >···</view>
          </view>
        </block>
      </block>

      <view wx:else class="drawer-empty">还没有历史会话</view>
    </scroll-view>
  </view>
</view>