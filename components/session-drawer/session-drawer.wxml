<view wx:if="{{visible}}">
  <view class="drawer-mask" bindtap="onMaskTap"></view>

  <view class="drawer drawer-open">
    <view class="drawer-header">
      <view class="drawer-title">{{title}}</view>
      <button size="mini" bindtap="onNewTap">新对话</button>
    </view>

    <scroll-view scroll-y class="drawer-list">
      <block wx:if="{{sessions.length === 0}}">
        <view class="drawer-empty">还没有历史会话</view>
      </block>

      <block wx:for="{{sessions}}" wx:key="session_id">
        <view
          class="drawer-item {{item.session_id === currentSessionId ? 'drawer-item-active' : ''}}"
          data-sessionid="{{item.session_id}}"
          data-title="{{item.title}}"
          bindtap="onSessionTap"
          bindlongpress="onSessionLongPress"
        >
          <view class="drawer-item-main">
            <view class="drawer-item-title">
              {{item.title || '新对话'}}
            </view>
          </view>

          <view
            class="drawer-delete-btn"
            data-sessionid="{{item.session_id}}"
            catchtap="onDeleteTap"
          >
            ×
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>