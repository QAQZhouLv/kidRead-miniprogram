.drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 31, 18, 0.18);
  z-index: 140;
}

.drawer {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 78%;
  max-width: 640rpx;
  background: #fff8ec;
  z-index: 150;
  transform: translateX(0);
  display: flex;
  flex-direction: column;
  padding: 24rpx 24rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 24rpx 0 40rpx rgba(0,0,0,0.08);
  border-top-right-radius: 28rpx;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-header button {
  margin: 0;
  border-radius: 999rpx;
  border: none;
  background: #60AB70;
  color: #fff;
}

.drawer-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #4f473a;
}

.drawer-list {
  flex: 1;
  margin-top: 24rpx;
}

.drawer-empty {
  color: #938775;
  padding: 20rpx 8rpx;
}

.drawer-item {
  background: rgba(255, 253, 246, 0.96);
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
}

.drawer-item-active {
  border: 3rpx solid #60AB70;
}

.drawer-item-main {
  flex: 1;
  min-width: 0;
}

.drawer-item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a4337;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.drawer-group-title {
  font-size: 24rpx;
  color: #8d816f;
  margin: 18rpx 8rpx 12rpx;
}

.drawer-more-btn {
  min-width: 56rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #f4ecda;
  color: #766b5c;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-size: 30rpx;
}