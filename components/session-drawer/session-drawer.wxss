.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.18);
  z-index: 140;
}

.drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 78%;
  max-width: 640rpx;
  background: #f6f6f6;
  z-index: 150;
  transform: translateX(0);
  display: flex;
  flex-direction: column;
  padding: 40rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-title {
  font-size: 38rpx;
  font-weight: 700;
}

.drawer-list {
  flex: 1;
  margin-top: 24rpx;
}

.drawer-empty {
  color: #999;
  padding: 20rpx 8rpx;
}

.drawer-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-item-active {
  border: 2rpx solid #1677ff;
}

.drawer-item-main {
  flex: 1;
  min-width: 0;
}

.drawer-item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.drawer-delete-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f2f2f2;
  color: #888;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-size: 34rpx;
}

.drawer-group-title {
  font-size: 24rpx;
  color: #888;
  margin: 18rpx 8rpx 12rpx;
}

.drawer-more-btn {
  min-width: 56rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #f2f2f2;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-size: 30rpx;
}