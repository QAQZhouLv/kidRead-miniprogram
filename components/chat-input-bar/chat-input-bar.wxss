.input-bar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 24rpx;
  box-sizing: border-box;
  z-index: 99;
  background: transparent;
}

.input-bar {
  min-height: 100rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 14rpx 30rpx rgba(81, 67, 44, 0.08);
}

.left-icon-btn,
.right-icon-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex-shrink: 0;
  box-shadow: 0 8rpx 18rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.left-icon-btn { margin-right: 16rpx; }
.right-icon-btn { margin-left: 16rpx; }

.text-input {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 28rpx;
}

.voice-press-area {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 999rpx;
  transition: all 0.12s ease;
}

.voice-press-area-active {
  transform: translateY(4rpx) scale(0.985);
}

.voice-main-text {
  font-size: 30rpx;
  font-weight: 700;
}

.voice-anim-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  animation: dotPulse 1s infinite ease-in-out;
  opacity: 0.35;
}

.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.25; transform: scale(0.9); }
  40% { opacity: 1; transform: scale(1.18); }
}
