.input-bar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 24rpx;
  box-sizing: border-box;
  z-index: 99;
  background: transparent;
}

.input-bar {
  background: #f4f4f4;
  border-radius: 36rpx;
  min-height: 96rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.left-icon-btn,
.right-icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid #111;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.left-icon-btn {
  margin-right: 20rpx;
}

.right-icon-btn {
  margin-left: 20rpx;
}

.icon-text {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.text-input {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 28rpx;
  color: #222;
}

.voice-press-area {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #111;
  font-weight: 600;
  border-radius: 24rpx;
  transition: all 0.12s ease;
}

.voice-press-area-active {
  transform: translateY(4rpx) scale(0.985);
  background: #ebebeb;
  box-shadow: inset 0 6rpx 14rpx rgba(0, 0, 0, 0.08);
}

.voice-main-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
}

.voice-anim-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #bdbdbd;
  animation: dotPulse 1s infinite ease-in-out;
  opacity: 0.35;
}

.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% {
    opacity: 0.25;
    transform: scale(0.9);
  }
  40% {
    opacity: 1;
    transform: scale(1.18);
  }
}